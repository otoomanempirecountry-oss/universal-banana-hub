local current = Scripts[GameId]

if current then
    Status.Text = "Authenticated: " .. current.Name
    Status.TextColor3 = Color3.fromRGB(0, 255, 100)
    
    ExecBtn.MouseButton1Click:Connect(function()
        ExecBtn.Text = "INJECTING..."
        
        local success, err = pcall(function()
            loadstring(game:HttpGet(current.Raw))()
        end)
        
        if success then
            Notify("Banana Hub Premium", current.Name .. " Loaded! 🍌👑")
            BananaLoader:Destroy()
        else
            Notify("Error", "Błąd ładowania skryptu.")
            warn(err)
            ExecBtn.Text = "RETRY"
        end
    end)
else
    Status.Text = "Game Not Supported ❌"
    Status.TextColor3 = Color3.fromRGB(255, 0, 0)
    ExecBtn.Text = "UNAVAILABLE"
    ExecBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
