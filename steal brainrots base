-- [[ 🍌 BANANA HUB | KAVO LOADER 🍌 ]] --

local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/xHeptc/Kavo-UI-Library/main/source.lua"))()
local Window = Library.CreateLib("🍌 BANANA HUB | PLOT MASTER", "DarkTheme")

-- Zmienne
_G.PlotCollect = false
_G.WalkSpeed = 16
local SelectedFloor = 1
local SelectedSlot = 1

-- Funkcja szukania działki
local function GetPlot()
    local name = game.Players.LocalPlayer.Name
    return workspace:FindFirstChild("Plot_" .. name) or workspace:FindFirstChild("Plot_banangames_1")
end

-- [[ LOGIKA ZBIERANIA ]] --
local function Collect()
    local plot = GetPlot()
    local root = game.Players.LocalPlayer.Character and game.Players.LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not plot or not root then return end

    for f = 1, 10 do
        local floor = plot:FindFirstChild("Floor" .. f)
        if floor and floor:FindFirstChild("Slots") then
            for s = 1, 10 do
                local slot = floor.Slots:FindFirstChild("Slot" .. s)
                if slot then
                    for _, obj in pairs(slot:GetDescendants()) do
                        if obj:IsA("BasePart") then
                            firetouchinterest(root, obj, 0)
                            firetouchinterest(root, obj, 1)
                        end
                    end
                end
            end
        end
    end
end

-- [[ LOGIKA UPGRADE ]] --
local function SafeUpgrade()
    local remote = game:GetService("ReplicatedStorage"):WaitForChild("Events"):WaitForChild("RequestSlotUpgrade")
    local plot = GetPlot()
    if not remote or not plot then return end

    task.spawn(function()
        for f = 1, 10 do
            local fName = "Floor" .. f
            if plot:FindFirstChild(fName) then
                for s = 1, 10 do
                    remote:FireServer(fName, "Slot" .. s)
                    task.wait(0.4) -- Bezpieczny odstęp
                end
                task.wait(1)
            end
        end
    end)
end

-- [[ INTERFEJS KAVO ]] --

-- Tab: Collector
local Main = Window:NewTab("Collector")
local MainSection = Main:NewSection("Plot Collection")

MainSection:NewButton("COLLECT ALL ONCE", "Zbiera wszystko z 10 pięter", function()
    pcall(Collect)
end)

MainSection:NewToggle("AUTO COLLECT LOOP", "Automatyczne zbieranie co 1.5s", function(state)
    _G.PlotCollect = state
    task.spawn(function()
        while _G.PlotCollect do
            pcall(Collect)
            task.wait(1.5)
        end
    end)
end)

-- Tab: Upgrades
local Upgrade = Window:NewTab("Upgrades")
local UpSection = Upgrade:NewSection("Safe Upgrade System")

UpSection:NewButton("SAFE UPGRADE ALL (1-10)", "Ulepsza wszystkie sloty powoli", function()
    SafeUpgrade()
end)

UpSection:NewSlider("Wybierz Piętro", "Wybierz piętro do ręcznego upgrade", 10, 1, function(s)
    SelectedFloor = s
end)

UpSection:NewSlider("Wybierz Slot", "Wybierz slot do ręcznego upgrade", 10, 1, function(s)
    SelectedSlot = s
end)

UpSection:NewButton("UPGRADE SELECTED SLOT", "Ulepsza wybrany slot", function()
    local remote = game:GetService("ReplicatedStorage"):WaitForChild("Events"):WaitForChild("RequestSlotUpgrade")
    remote:FireServer("Floor" .. SelectedFloor, "Slot" .. SelectedSlot)
end)

-- Tab: Player
local Player = Window:NewTab("Player")
local PSection = Player:NewSection("Movement")

PSection:NewSlider("WalkSpeed", "Zmień prędkość chodzenia", 200, 16, function(s)
    _G.WalkSpeed = s
end)

-- Pętla Speed (Anti-Reset)
task.spawn(function()
    while true do
        local hum = game.Players.LocalPlayer.Character and game.Players.LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        if hum then hum.WalkSpeed = _G.WalkSpeed end
        task.wait(0.5)
    end
end)

-- Tab: Misc
local Misc = Window:NewTab("Misc")
Misc:NewSection("Settings")
Misc:NewButton("FORCE RESPAWN", "Resetuje postać", function()
    game.Players.LocalPlayer.Character:BreakJoints()
end)
