-- [AUTO-ORBS]
local OrbsToggle = MainTab:CreateToggle({
   Name = "Auto Orbs",
   CurrentValue = false,
   Flag = "Toggle1",
   Callback = function(Value)
      _G.Farm1 = Value
      task.spawn(function()
          while _G.Farm1 do task.wait()
             for i,v in pairs(game.Workspace.orbFolder.City:GetChildren()) do
                if v.Name ~= "Gem" then v.outerOrb.CFrame = game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame end
             end
          end
      end)
   end,
})

-- [AUTO-STEPS]
local OrangeOrbsToggle = MainTab:CreateToggle({
   Name = "Auto Steps",
   CurrentValue = false,
   Flag = "Toggle2",
   Callback = function(Value)
      _G.Steps = Value
      task.spawn(function()
          while _G.Steps do
              game:GetService("ReplicatedStorage").rEvents.orbEvent:FireServer("collectOrb", "Orange Orb", "City")
              task.wait(0.1)
          end
      end)
   end,
})

-- [AUTO-REBIRTHS]
local RebirthsToggle = MainTab:CreateToggle({
   Name = "Auto Rebirths",
   CurrentValue = false,
   Flag = "Toggle3",
   Callback = function(Value)
