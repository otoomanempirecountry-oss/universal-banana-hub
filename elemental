        if p ~= LPlayer then
            local Card = Instance.new("Frame", Scroll)
            Card.Size = UDim2.new(1, -5, 0, 40)
            Card.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
            Instance.new("UICorner", Card)

            local TeamStrip = Instance.new("Frame", Card)
            TeamStrip.Size = UDim2.new(0, 5, 1, 0)
            TeamStrip.BackgroundColor3 = p.TeamColor and p.TeamColor.Color or Color3.new(1,1,1)

            local Name = Instance.new("TextLabel", Card)
            Name.Position = UDim2.new(0, 12, 0, 0)
            Name.Size = UDim2.new(1, -15, 1, 0)
            Name.Text = p.Name .. " [" .. (p.Team and p.Team.Name or "No Team") .. "]"
            Name.TextColor3 = p.TeamColor and p.TeamColor.Color or Color3.new(1,1,1)
            Name.Font = Enum.Font.GothamBold
            Name.TextXAlignment = Enum.TextXAlignment.Left
