            b.BackgroundTransparency = 1
            b.Text = ""
            b.MouseButton1Click:Connect(function() KillTarget(p) end)
        end
    end
end

-- [[ 6. GIVER & NAV ]] --
local isGiving = false
local function GiveSpells()
    if isGiving then return end
    isGiving = true
    task.spawn(function()
        for _, name in ipairs(spells_only) do
            if not isGiving then break end
            ReplicatedStorage.RemoteEvent:FireServer("equip_mystery_spell", name)
            task.wait(4)
        end
        isGiving = false
    end)
end

