-- [[ 3. ANTI-PUSH LOGIC ]] --
local antiPushActive = false
local function ToggleAntiPush()
    antiPushActive = not antiPushActive
    Status.Text = antiPushActive and "ANTY-BEAM: AKTYWNY" or "ANTY-BEAM: OFF"
    Status.TextColor3 = antiPushActive and Color3.new(0, 1, 0) or Color3.new(1, 0, 0)
    task.spawn(function()
        while antiPushActive do
            if LPlayer.Character and LPlayer.Character:FindFirstChild("HumanoidRootPart") then
                local root = LPlayer.Character.HumanoidRootPart
                root.Velocity = Vector3.new(0,0,0)
                for _, v in pairs(root:GetChildren()) do
                    if v:IsA("BodyMover") then v:Destroy() end
                end
            end
            RunService.Stepped:Wait()
        end
    end)
end

-- [[ 4. IMPROVED ANCHOR KILLER ]] --
local function KillTarget(p)
    local char = LPlayer.Character
    local targetChar = p.Character
    if char and targetChar and targetChar:FindFirstChild("HumanoidRootPart") then
        local root = char:FindFirstChild("HumanoidRootPart")
        local tRoot = targetChar.HumanoidRootPart
        
        -- Zamrażamy postać, żeby nie spadła/nie odleciała
        root.Anchored = true
        
        local attackTime = 0
        local connection
        connection = RunService.Heartbeat:Connect(function()
            if targetChar and tRoot and attackTime < 40 then -- ok. 2-3 sekundy ataku
                root.CFrame = tRoot.CFrame * CFrame.new(0, 0, 2)
                attackTime = attackTime + 1
            else
                root.Anchored = false
                connection:Disconnect()
            end
        end)

        task.spawn(function()
            for i = 1, 10 do
                for _, tool in pairs(LPlayer.Backpack:GetChildren()) do
                    if tool:IsA("Tool") then
                        char.Humanoid:EquipTool(tool)
                        tool:Activate()
                    end
                end
                task.wait(0.15)
            end
            root.Anchored = false
        end)
    end
end

